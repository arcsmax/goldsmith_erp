# Goldsmith ERP - Environment Variables Configuration
# Copy this file to .env and update the values

# =====================================================
# SERVER SETTINGS
# =====================================================
HOST=0.0.0.0
PORT=8000
DEBUG=true

# =====================================================
# SECURITY - IMPORTANT!
# =====================================================
# Generate a secure SECRET_KEY with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# NEVER use the default value in production!
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS

# Token expiration time in minutes (default: 8 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# =====================================================
# DATABASE (PostgreSQL)
# =====================================================
POSTGRES_USER=user
# REQUIRED — dev compose files (docker-compose.yml, podman-compose.yml)
# will refuse to start without this. Use any value locally, but NEVER reuse
# this placeholder in production. Production uses podman-compose.prod.yml
# which reads DB_PASSWORD from a secret manager.
POSTGRES_PASSWORD=changeme
POSTGRES_DB=goldsmith
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Dev DB port binds to 127.0.0.1 by default. Set DB_HOST_IP=0.0.0.0 (or a
# specific LAN IP) if you genuinely need the dev DB reachable from another
# machine. Do NOT do this on an untrusted network.
# DB_HOST_IP=127.0.0.1

# Optional: Override the entire DATABASE_URL
# DATABASE_URL=postgresql+asyncpg://user:changeme@db:5432/goldsmith

# =====================================================
# REDIS (Caching & Pub/Sub)
# =====================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Optional: Override the entire REDIS_URL
# REDIS_URL=redis://redis:6379/0

# =====================================================
# CORS (Cross-Origin Resource Sharing)
# =====================================================
# Allowed origins for CORS (comma-separated or JSON array)
BACKEND_CORS_ORIGINS='["http://localhost:3000","http://localhost:8000"]'

# ====================================================================
# ANONYMIZATION SALT (GDPR Art. 17 — pseudonymization)
# ====================================================================
# HMAC salt for user-anonymization sentinel derivation.
#
# DO NOT ROTATE this value after the first erasure event has been
# processed. Rotating invalidates all prior anonymization hashes —
# previously anonymized records become unlinkable to the original
# sentinel, which destroys the audit trail that Art. 17 explicitly
# permits preserving.
#
# If compromised: consult DPO and plan a controlled rotation with
# re-processing of all affected sentinel records.
#
# Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
#
# See docs/superpowers/plans/qr-barcode-workflow/
# V1.1-ANONYMIZE-USER-CONTRACT.md §4 for the full rotation policy.
ANONYMIZATION_SALT=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS

# =====================================================
# OPTIONAL: EMAIL (for notifications)
# =====================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@goldsmith-erp.local

# =====================================================
# FILE STORAGE ROOT (GDPR Art. 17 file erasure)
# =====================================================
# Root directory for filesystem artefacts referenced by DB path columns
# (generated PDFs, uploaded photos, scrap-gold receipts).
#
# The FileErasureService deletes every file referenced by a row linked to
# an erased customer. It refuses to delete any path that escapes this
# root (path-traversal guard).
#
# Production deployments MUST override with a path that contains ONLY the
# uploaded / generated artefact tree.
FILE_STORAGE_ROOT=./uploads

# =====================================================
# OPTIONAL: FILE STORAGE (AWS S3, MinIO, etc.)
# =====================================================
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=goldsmith-uploads
# AWS_REGION=eu-central-1
